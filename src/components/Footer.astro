---
import { NAV_LINKS } from "../consts";
const currentYear = new Date().getFullYear();
---

<footer class="bg-forest-950 text-white pt-16 pb-8">
  <div class="container-custom">
    <!-- Main Footer Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-12">
      <!-- Column 1: Company -->
      <div>
        <a href="/" class="inline-block mb-4 no-underline">
          <span class="text-2xl font-heading font-bold text-white tracking-wide">
            SURYA<span class="text-gold-400">FOODS</span>
          </span>
        </a>
        <p class="text-sm text-forest-300/70 leading-relaxed mb-6">
          An internationally certified export house, milling premium Basmati
          rice since 1999. Trusted by partners in 15+ countries worldwide.
        </p>
        <!-- Social Links -->
        <div class="flex gap-4">
          <a
            href="https://linkedin.com/company/suryafoods"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-full bg-forest-800/60 flex items-center justify-center text-forest-300 hover:bg-gold-400 hover:text-white transition-all duration-300"
            aria-label="LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a
            href="https://instagram.com/suryafoods"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-full bg-forest-800/60 flex items-center justify-center text-forest-300 hover:bg-gold-400 hover:text-white transition-all duration-300"
            aria-label="Instagram"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a
            href="https://facebook.com/suryafoods"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-full bg-forest-800/60 flex items-center justify-center text-forest-300 hover:bg-gold-400 hover:text-white transition-all duration-300"
            aria-label="Facebook"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a
            href="/rss.xml"
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-full bg-forest-800/60 flex items-center justify-center text-forest-300 hover:bg-gold-400 hover:text-white transition-all duration-300"
            aria-label="RSS Feed"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93v-2.83z"/></svg>
          </a>
        </div>
      </div>

      <!-- Column 2: Quick Links -->
      <div>
        <h4 class="text-sm font-body font-semibold uppercase tracking-widest text-gold-400 mb-5">
          Quick Links
        </h4>
        <ul class="space-y-3 list-none p-0 m-0">
          {NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-forest-300/70 hover:text-gold-300 transition-colors duration-300 no-underline"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Export Inquiries -->
      <div>
        <h4 class="text-sm font-body font-semibold uppercase tracking-widest text-gold-400 mb-5">
          Export Inquiries
        </h4>
        <ul class="space-y-4 list-none p-0 m-0">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-gold-400 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:exports@suryafoods.com" class="text-sm text-forest-300/70 hover:text-gold-300 transition-colors duration-300 no-underline">
              exports@suryafoods.com
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-gold-400 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+91XXXXXXXXXX" class="text-sm text-forest-300/70 hover:text-gold-300 transition-colors duration-300 no-underline">
              +91-XXXXXXXXXX
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-gold-400 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="text-sm text-forest-300/70">
              Haryana, India
            </span>
          </li>
        </ul>
      </div>

      <!-- Column 4: Certifications -->
      <div>
        <h4 class="text-sm font-body font-semibold uppercase tracking-widest text-gold-400 mb-5">
          Certifications
        </h4>
        <ul class="space-y-3 list-none p-0 m-0">
          {["ISO 22000:2018", "FSSAI Certified", "Govt. Export House", "APEDA Registered"].map((cert) => (
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-forest-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <span class="text-sm text-forest-300/70">{cert}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-transparent via-gold-400/30 to-transparent mb-8"></div>

    <!-- Bottom Bar -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-forest-400/60 m-0">
        &copy; {currentYear} Surya Foods. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="#" class="text-xs text-forest-400/60 hover:text-forest-300 transition-colors duration-300 no-underline">
          Privacy Policy
        </a>
        <a href="#" class="text-xs text-forest-400/60 hover:text-forest-300 transition-colors duration-300 no-underline">
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
