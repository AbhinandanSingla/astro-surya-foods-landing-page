---
import { PRODUCTS, INDIAN_STATES } from "../consts";

interface Props {
  formId: string;
  formType: "export" | "distributor";
  heading: string;
  subtitle?: string;
}

const { formId, formType, heading, subtitle } = Astro.props;
---

<div id={formId} class="scroll-mt-32">
  <div class="bg-forest-900 section-padding">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16 items-start">
        <!-- Left Column: Info -->
        <div class="lg:col-span-2" data-animate>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold-300 mb-4">
            {formType === "export" ? "International Trade" : "Distribution"}
          </p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-white mb-4 leading-tight">
            {heading}
          </h2>
          <div class="gold-line mb-6"></div>
          {subtitle && (
            <p class="text-base text-forest-200/70 leading-relaxed mb-8">
              {subtitle}
            </p>
          )}

          {formType === "export" ? (
            <ul class="space-y-4 list-none p-0 m-0">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <span class="text-sm text-forest-200/70">exports@suryafoods.com</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <span class="text-sm text-forest-200/70">+91-XXXXXXXXXX</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-gold-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="text-sm text-forest-200/70">Haryana, India</span>
              </li>
            </ul>
          ) : (
            <ul class="space-y-3 list-none p-0 m-0">
              {[
                "Attractive distributor margins",
                "Marketing and POS material support",
                "Dedicated account manager",
                "Flexible MOQ for new partners",
              ].map((benefit) => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-gold-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-sm text-forest-200/70">{benefit}</span>
                </li>
              ))}
            </ul>
          )}
        </div>

        <!-- Right Column: Form -->
        <div class="lg:col-span-3" data-animate>
          <form
            id={`${formId}-form`}
            class="bg-white rounded-2xl p-6 md:p-8 shadow-2xl"
            novalidate
          >
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">
              <!-- Full Name -->
              <div>
                <label for={`${formId}-fullName`} class="block text-sm font-medium text-slate-700 mb-1.5">
                  Full Name <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id={`${formId}-fullName`}
                  name="fullName"
                  required
                  placeholder={formType === "export" ? "e.g., John Smith" : "e.g., Rajesh Kumar"}
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-slate-800 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 focus:bg-white transition-all duration-200"
                />
                <span class="text-red-600 text-xs mt-1 hidden" data-error="fullName">This field is required.</span>
              </div>

              <!-- Company/Business Name -->
              <div>
                <label for={`${formId}-companyName`} class="block text-sm font-medium text-slate-700 mb-1.5">
                  {formType === "export" ? "Company Name" : "Business Name"} <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id={`${formId}-companyName`}
                  name={formType === "export" ? "companyName" : "businessName"}
                  required
                  placeholder={formType === "export" ? "e.g., Global Rice Trading Co." : "e.g., Kumar Distributors Pvt. Ltd."}
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-slate-800 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 focus:bg-white transition-all duration-200"
                />
                <span class="text-red-600 text-xs mt-1 hidden" data-error="companyName">This field is required.</span>
              </div>

              <!-- Country / City -->
              <div>
                <label for={`${formId}-location`} class="block text-sm font-medium text-slate-700 mb-1.5">
                  {formType === "export" ? "Country" : "City / Region"} <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id={`${formId}-location`}
                  name={formType === "export" ? "country" : "city"}
                  required
                  placeholder={formType === "export" ? "e.g., United Arab Emirates" : "e.g., Jaipur, Rajasthan"}
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-slate-800 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 focus:bg-white transition-all duration-200"
                />
                <span class="text-red-600 text-xs mt-1 hidden" data-error="location">This field is required.</span>
              </div>

              <!-- State (distributor only) / Email -->
              {formType === "distributor" ? (
                <div>
                  <label for={`${formId}-state`} class="block text-sm font-medium text-slate-700 mb-1.5">
                    State <span class="text-red-500">*</span>
                  </label>
                  <select
                    id={`${formId}-state`}
                    name="state"
                    required
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 focus:bg-white transition-all duration-200 appearance-none"
                  >
                    <option value="">Select your state</option>
                    {INDIAN_STATES.map((state) => (
                      <option value={state}>{state}</option>
                    ))}
                  </select>
                  <span class="text-red-600 text-xs mt-1 hidden" data-error="state">Please select your state.</span>
                </div>
              ) : null}

              <!-- Email -->
              <div>
                <label for={`${formId}-email`} class="block text-sm font-medium text-slate-700 mb-1.5">
                  Business Email <span class="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  id={`${formId}-email`}
                  name="email"
                  required
                  placeholder="e.g., name@company.com"
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-slate-800 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 focus:bg-white transition-all duration-200"
                />
                <span class="text-red-600 text-xs mt-1 hidden" data-error="email">Please enter a valid email address.</span>
              </div>

              <!-- Phone -->
              <div>
                <label for={`${formId}-phone`} class="block text-sm font-medium text-slate-700 mb-1.5">
                  Phone Number <span class="text-red-500">*</span>
                </label>
                <input
                  type="tel"
                  id={`${formId}-phone`}
                  name="phone"
                  required
                  placeholder={formType === "export" ? "e.g., +971-50-1234567" : "e.g., +91-9876543210"}
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-slate-800 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 focus:bg-white transition-all duration-200"
                />
                <span class="text-red-600 text-xs mt-1 hidden" data-error="phone">Please enter a valid phone number.</span>
              </div>

              {/* Export: Products multi-select */}
              {formType === "export" && (
                <div class="md:col-span-2">
                  <label for={`${formId}-products`} class="block text-sm font-medium text-slate-700 mb-1.5">
                    Interested Products <span class="text-red-500">*</span>
                  </label>
                  <select
                    id={`${formId}-products`}
                    name="products"
                    multiple
                    required
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 focus:bg-white transition-all duration-200 min-h-[120px]"
                  >
                    {PRODUCTS.map((product) =>
                      product.forms.map((form) => (
                        <option value={`${product.name.toLowerCase().replace(/\s+/g, "-")}-${form.toLowerCase()}`}>
                          {product.name} — {form}
                        </option>
                      ))
                    )}
                    <option value="other">Other (specify in message)</option>
                  </select>
                  <p class="text-xs text-slate-400 mt-1">Hold Ctrl/Cmd to select multiple</p>
                  <span class="text-red-600 text-xs mt-1 hidden" data-error="products">Please select at least one product.</span>
                </div>
              )}

              {/* Export: Volume */}
              {formType === "export" && (
                <div class="md:col-span-2">
                  <label for={`${formId}-volume`} class="block text-sm font-medium text-slate-700 mb-1.5">
                    Annual Volume Requirements
                  </label>
                  <input
                    type="text"
                    id={`${formId}-volume`}
                    name="volume"
                    placeholder="e.g., 500 MT per year"
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-slate-800 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 focus:bg-white transition-all duration-200"
                  />
                </div>
              )}

              {/* Distributor: Network */}
              {formType === "distributor" && (
                <div class="md:col-span-2">
                  <label for={`${formId}-network`} class="block text-sm font-medium text-slate-700 mb-1.5">
                    Describe Your Current Distribution Network
                  </label>
                  <textarea
                    id={`${formId}-network`}
                    name="network"
                    rows="3"
                    placeholder="Tell us about your existing retail/wholesale network, fleet size, coverage area..."
                    class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-slate-800 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 focus:bg-white transition-all duration-200 resize-vertical"
                  ></textarea>
                </div>
              )}

              <!-- Message -->
              <div class="md:col-span-2">
                <label for={`${formId}-message`} class="block text-sm font-medium text-slate-700 mb-1.5">
                  Additional Message
                </label>
                <textarea
                  id={`${formId}-message`}
                  name="message"
                  rows="4"
                  placeholder={formType === "export"
                    ? "Tell us about your requirements, preferred Incoterms, packaging needs..."
                    : "Any other details you'd like to share..."
                  }
                  class="w-full px-4 py-3 bg-slate-50 border border-slate-200 rounded-lg text-slate-800 text-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 focus:ring-forest-500/30 focus:border-forest-500 focus:bg-white transition-all duration-200 resize-vertical"
                ></textarea>
              </div>

              <!-- Submit -->
              <div class="md:col-span-2">
                <button type="submit" class="btn-primary w-full !text-sm">
                  {formType === "export" ? "Submit Inquiry" : "Apply for Distribution"}
                </button>
              </div>
            </div>

            <!-- Success State (hidden by default) -->
            <div id={`${formId}-success`} class="hidden text-center py-8">
              <div class="w-16 h-16 rounded-full bg-forest-100 flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-forest-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="text-xl font-heading font-bold text-slate-900 mb-2">
                {formType === "export" ? "Inquiry Received!" : "Application Received!"}
              </h3>
              <p class="text-sm text-slate-600">
                {formType === "export"
                  ? "Thank you! Our export team will contact you within 24 business hours."
                  : "Thank you! Our distribution team will review your application and contact you within 3-5 business days."
                }
              </p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ formId }}>
  const form = document.getElementById(`${formId}-form`);
  const successDiv = document.getElementById(`${formId}-success`);

  if (form) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      let isValid = true;

      // Reset errors
      form.querySelectorAll("[data-error]").forEach((el) => el.classList.add("hidden"));
      form.querySelectorAll("input, select, textarea").forEach((el) => {
        el.classList.remove("!border-red-500");
      });

      // Validate required fields
      form.querySelectorAll("[required]").forEach((field) => {
        const input = field;
        let fieldValid = true;

        if (input.type === "email") {
          fieldValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value);
        } else if (input.type === "tel") {
          fieldValid = /^[\+]?[\d\s\-\(\)]{7,20}$/.test(input.value);
        } else if (input.tagName === "SELECT" && !input.multiple) {
          fieldValid = input.value !== "";
        } else if (input.tagName === "SELECT" && input.multiple) {
          fieldValid = input.selectedOptions.length > 0;
        } else {
          fieldValid = input.value.trim().length >= 2;
        }

        if (!fieldValid) {
          isValid = false;
          input.classList.add("!border-red-500");
          const errorKey = input.getAttribute("data-error-key") || input.name || input.id.split("-").pop();
          const errorEl = form.querySelector(`[data-error="${errorKey}"]`) ||
                          input.parentElement?.querySelector("[data-error]");
          if (errorEl) errorEl.classList.remove("hidden");
        }
      });

      if (isValid) {
        // Simulate submission
        const submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn) {
          submitBtn.textContent = "Submitting...";
          submitBtn.disabled = true;
          submitBtn.classList.add("opacity-75", "cursor-not-allowed");
        }

        setTimeout(() => {
          // Show success, hide form fields
          const formGrid = form.querySelector(".grid");
          if (formGrid) formGrid.classList.add("hidden");
          if (successDiv) successDiv.classList.remove("hidden");
        }, 1500);
      }
    });

    // Clear errors on input
    form.querySelectorAll("input, select, textarea").forEach((field) => {
      field.addEventListener("input", () => {
        field.classList.remove("!border-red-500");
        const errorEl = field.parentElement?.querySelector("[data-error]");
        if (errorEl) errorEl.classList.add("hidden");
      });
    });
  }
</script>
