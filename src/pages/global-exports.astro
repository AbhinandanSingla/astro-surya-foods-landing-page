---
import MasterLayout from "../layouts/MasterLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProductCard from "../components/ProductCard.astro";
import LeadForm from "../components/LeadForm.astro";
import { PRODUCTS } from "../consts";
---

<MasterLayout
  title="Global Exports — Surya Foods"
  description="Export premium Indian Basmati rice worldwide. Surya Foods offers 1121, 1509, 1718, and Pusa Basmati in Raw, Steam, and Sella forms. Internationally certified export house."
  transparentNav={true}
>
  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="relative min-h-[70vh] flex items-center">
    <img
      src="https://images.unsplash.com/photo-1578575437130-527eed3abbec?w=1920&q=80"
      alt="International shipping port with cargo containers"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-forest-950/95 via-forest-950/80 to-forest-950/50"></div>

    <div class="relative z-10 container-custom py-32 md:py-40">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-gold-400 mb-6">
          International Trade
        </p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-heading font-bold text-white leading-[1.1] mb-6">
          Exporting India's Finest Basmati<br />
          <span class="text-gradient-gold">to the World</span>
        </h1>
        <p class="text-base md:text-lg text-forest-100/80 leading-relaxed max-w-xl">
          As an internationally certified export house, we deliver premium Basmati rice to 15+ countries with unmatched consistency and compliance.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ EXPORT OVERVIEW ═══════════════════ -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <SectionHeading
        overline="Why Surya Foods"
        title="A Global Partner You Can Trust"
      />

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Feature 1 -->
        <div class="text-center p-6 md:p-8 rounded-2xl bg-forest-50/50 border border-forest-100 hover:shadow-lg transition-all duration-500" data-animate>
          <div class="w-16 h-16 rounded-2xl bg-forest-100 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-forest-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-lg font-heading font-bold text-slate-900 mb-3">Certified Quality</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            ISO 22000:2018, FSSAI, APEDA registered. Every shipment meets the strictest international food safety standards. In-house quality lab tests every batch.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="text-center p-6 md:p-8 rounded-2xl bg-forest-50/50 border border-forest-100 hover:shadow-lg transition-all duration-500" data-animate>
          <div class="w-16 h-16 rounded-2xl bg-forest-100 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-forest-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-heading font-bold text-slate-900 mb-3">Flexible Logistics</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            FOB, CIF, and CFR terms available. We handle all export documentation including fumigation certificates, phytosanitary certificates, and customs clearance.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="text-center p-6 md:p-8 rounded-2xl bg-forest-50/50 border border-forest-100 hover:shadow-lg transition-all duration-500" data-animate>
          <div class="w-16 h-16 rounded-2xl bg-forest-100 flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-forest-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
            </svg>
          </div>
          <h3 class="text-lg font-heading font-bold text-slate-900 mb-3">Custom Packaging</h3>
          <p class="text-sm text-slate-600 leading-relaxed">
            Private labeling and custom packaging from 1kg consumer packs to 50kg bulk bags. Your brand, our rice. Automated packaging lines ensure consistency.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ PRODUCT GRID ═══════════════════ -->
  <section class="section-padding bg-cream">
    <div class="container-custom">
      <SectionHeading
        overline="Our Range"
        title="Premium Basmati Rice Grades"
        subtitle="Each variety is carefully selected and processed to meet international quality benchmarks."
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {PRODUCTS.map((product) => (
          <ProductCard
            name={product.name}
            image={product.image}
            description={product.description}
            forms={product.forms}
            grade={product.grade}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════ WHY PARTNER ═══════════════════ -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Image -->
        <div data-animate>
          <div class="rounded-2xl overflow-hidden shadow-2xl">
            <img
              src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=800&q=80"
              alt="Quality testing laboratory"
              loading="lazy"
              decoding="async"
              class="w-full h-[400px] md:h-[480px] object-cover"
            />
          </div>
        </div>

        <!-- Content -->
        <div data-animate>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold-500 mb-4">
            Our Advantage
          </p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-slate-900 leading-tight mb-4">
            The Surya Foods Advantage
          </h2>
          <div class="gold-line mb-8"></div>

          <div class="space-y-6">
            {[
              {
                title: "DGFT Registered Export House",
                desc: "Registered with DGFT as an established export house. Full compliance with all international export regulations and trade standards.",
              },
              {
                title: "In-house Quality Labs",
                desc: "Every batch tested for moisture content, grain length, aroma index, broken percentage, and foreign matter.",
              },
              {
                title: "Competitive Pricing",
                desc: "Direct from our mill to your port — no middlemen, no inflated costs. Transparent pricing with volume incentives.",
              },
              {
                title: "Consistent Supply",
                desc: "50,000+ MT annual processing capacity ensures year-round availability even during peak seasons.",
              },
              {
                title: "Trade Compliance",
                desc: "Complete documentation support — commercial invoices, packing lists, certificates of origin, and phytosanitary reports.",
              },
            ].map((item, i) => (
              <div class="flex gap-4">
                <div class="shrink-0 w-8 h-8 rounded-full bg-forest-100 flex items-center justify-center mt-0.5">
                  <span class="text-xs font-bold text-forest-700">{String(i + 1).padStart(2, "0")}</span>
                </div>
                <div>
                  <h4 class="text-base font-heading font-bold text-slate-900 mb-1">{item.title}</h4>
                  <p class="text-sm text-slate-600 leading-relaxed m-0">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ LEAD FORM ═══════════════════ -->
  <LeadForm
    formId="inquiry-form"
    formType="export"
    heading="Start Your Export Partnership"
    subtitle="Fill out the form below and our export team will get back to you within 24 business hours with a detailed quote and product catalog."
  />
</MasterLayout>
