---
interface Props {
  href: string;
  class?: string;
}

const { href, class: className } = Astro.props;
const isActive = Astro.url.pathname === href || 
  (href !== "/" && Astro.url.pathname.startsWith(href));
---

<a
  href={href}
  class:list={[
    "relative px-1 py-2 text-sm font-medium tracking-wide transition-colors duration-300",
    isActive
      ? "text-gold-400"
      : "text-white/80 hover:text-gold-300",
    className,
  ]}
  aria-current={isActive ? "page" : undefined}
>
  <slot />
  {isActive && (
    <span class="absolute bottom-0 left-0 right-0 h-0.5 bg-gradient-to-r from-gold-400 to-gold-300 rounded-full" />
  )}
</a>
