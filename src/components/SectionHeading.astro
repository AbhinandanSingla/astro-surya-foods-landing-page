---
interface Props {
  overline?: string;
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  light?: boolean;
}

const { overline, title, subtitle, align = "center", light = false } = Astro.props;
---

<div class:list={["mb-12 md:mb-16", align === "center" ? "text-center" : "text-left"]} data-animate>
  {overline && (
    <p
      class:list={[
        "text-xs font-semibold uppercase tracking-[0.2em] mb-4",
        light ? "text-gold-300" : "text-gold-500",
      ]}
    >
      {overline}
    </p>
  )}
  <h2
    class:list={[
      "text-3xl md:text-4xl lg:text-[2.75rem] font-heading font-bold leading-tight mb-4",
      light ? "text-white" : "text-slate-900",
    ]}
  >
    {title}
  </h2>
  <div class:list={["gold-line mb-6", align === "center" ? "mx-auto" : ""]}></div>
  {subtitle && (
    <p
      class:list={[
        "text-base md:text-lg leading-relaxed max-w-2xl",
        align === "center" ? "mx-auto" : "",
        light ? "text-forest-200/70" : "text-slate-600",
      ]}
    >
      {subtitle}
    </p>
  )}
</div>
