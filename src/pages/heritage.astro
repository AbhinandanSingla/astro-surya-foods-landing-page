---
import MasterLayout from "../layouts/MasterLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import TimelineItem from "../components/TimelineItem.astro";
import CertificationBadge from "../components/CertificationBadge.astro";
import { TIMELINE, CERTIFICATIONS } from "../consts";
---

<MasterLayout
  title="Heritage & Quality — Surya Foods"
  description="Since 1999, Surya Foods has been a pillar of India's rice industry. Explore our journey, quality standards, and certifications that make us a trusted export partner."
  transparentNav={true}
>
  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="relative min-h-[70vh] flex items-center">
    <img
      src="https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=1920&q=80"
      alt="Heritage agricultural landscape with golden fields"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-forest-950/95 via-forest-950/80 to-forest-950/50"></div>

    <div class="relative z-10 container-custom py-32 md:py-40">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-gold-400 mb-6">
          Established 1999
        </p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-heading font-bold text-white leading-[1.1] mb-6">
          A Legacy Built<br />
          <span class="text-gradient-gold">on Quality</span>
        </h1>
        <p class="text-base md:text-lg text-forest-100/80 leading-relaxed max-w-xl">
          For over two decades, Surya Foods has been synonymous with trust, quality, and excellence in India's rice industry.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ COMPANY TIMELINE ═══════════════════ -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <SectionHeading
        overline="Our Journey"
        title="Milestones That Define Us"
        subtitle="From a small milling unit in 1999 to a global export powerhouse — every milestone reflects our unwavering commitment to excellence."
      />

      <div class="max-w-2xl mx-auto">
        {TIMELINE.map((item, i) => (
          <TimelineItem
            year={item.year}
            title={item.title}
            description={item.description}
            isLast={i === TIMELINE.length - 1}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════ OUR PROCESS ═══════════════════ -->
  <section class="section-padding bg-cream">
    <div class="container-custom">
      <SectionHeading
        overline="Quality Assurance"
        title="From Paddy to Plate"
        subtitle="Every grain goes through a rigorous multi-step quality process before it reaches our partners."
      />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          {
            step: "01",
            title: "Paddy Procurement",
            desc: "Direct sourcing from trusted farmer networks across India's premier rice belt regions, ensuring traceability from field to factory.",
            icon: "M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3",
          },
          {
            step: "02",
            title: "Milling & Husking",
            desc: "State-of-the-art rice milling equipment engineered for minimal grain breakage and maximum yield, preserving the integrity of every grain.",
            icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z",
          },
          {
            step: "03",
            title: "Sortex & Grading",
            desc: "Multi-pass color sorting and precision length grading technology ensures uniformity in grain size, color, and appearance across every batch.",
            icon: "M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z",
          },
          {
            step: "04",
            title: "Quality Lab Testing",
            desc: "In-house laboratory testing for moisture content, grain length, aroma index, broken grain percentage, and foreign matter — every batch, every time.",
            icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
          },
          {
            step: "05",
            title: "Packaging",
            desc: "Hygienic, automated packaging lines for consumer retail (1kg–10kg) and bulk export formats (25kg–50kg) with nitrogen flushing for freshness.",
            icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
          },
          {
            step: "06",
            title: "Export Compliance",
            desc: "Full fumigation, phytosanitary certification, certificates of origin, and customs documentation for hassle-free international trade.",
            icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
          },
        ].map((item) => (
          <div class="bg-white rounded-xl border border-slate-100 p-6 hover:shadow-lg transition-all duration-500 hover:-translate-y-1" data-animate>
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 rounded-xl bg-forest-50 flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-forest-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} />
                </svg>
              </div>
              <span class="text-xs font-bold text-gold-400 uppercase tracking-widest">Step {item.step}</span>
            </div>
            <h3 class="text-base font-heading font-bold text-slate-900 mb-2">{item.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed m-0">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════ CERTIFICATIONS GRID ═══════════════════ -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <SectionHeading
        overline="Trust & Compliance"
        title="Our Certifications & Licenses"
        subtitle="Every certificate represents our unwavering commitment to quality and food safety."
      />

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
        {CERTIFICATIONS.map((cert) => (
          <CertificationBadge
            name={cert.name}
            description={cert.description}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════ LEADERSHIP QUOTE ═══════════════════ -->
  <section class="section-padding bg-forest-900 relative overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
    </div>
    <div class="relative container-custom max-w-3xl mx-auto text-center" data-animate>
      <!-- Decorative Quote Mark -->
      <div class="text-6xl md:text-8xl font-heading text-gold-400/30 leading-none mb-6">"</div>
      <blockquote class="text-xl md:text-2xl font-heading font-medium text-white leading-relaxed mb-8 italic">
        Our commitment has always been simple — deliver the finest grain of rice, every single time. This is not just a business; it is a responsibility we carry with pride.
      </blockquote>
      <div class="gold-line mx-auto mb-6"></div>
      <p class="text-sm font-semibold text-gold-400 uppercase tracking-widest">
        — The Surya Foods Family, Since 1999
      </p>
    </div>
  </section>
</MasterLayout>
