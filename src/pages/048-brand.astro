---
import MasterLayout from "../layouts/MasterLayout.astro";
import SectionHeading from "../components/SectionHeading.astro";
import LeadForm from "../components/LeadForm.astro";
---

<MasterLayout
  title="048 Premium Rice — Surya Foods"
  description="Discover 048 by Surya Foods — premium Basmati rice for the discerning Indian household. Majesty and Platinum collections now available for Pan-India distribution."
  transparentNav={true}
>
  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="relative min-h-[70vh] flex items-center">
    <img
      src="https://images.unsplash.com/photo-1504674900247-0877df9cc836?w=1920&q=80"
      alt="Premium dining experience with rice"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      decoding="async"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-forest-950/95 via-forest-950/80 to-forest-950/50"></div>

    <div class="relative z-10 container-custom py-32 md:py-40">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.25em] text-gold-400 mb-6">
          Introducing
        </p>
        <h1 class="text-6xl sm:text-7xl md:text-8xl font-heading font-bold leading-none mb-4">
          <span class="text-gradient-gold">048</span>
        </h1>
        <p class="text-2xl md:text-3xl font-heading font-semibold text-white mb-6">
          The Pinnacle of Everyday Luxury
        </p>
        <p class="text-base md:text-lg text-forest-100/80 leading-relaxed max-w-xl">
          Crafted from the finest Basmati grains, 048 brings restaurant-quality rice to your home. Two exceptional collections for every occasion.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ BRAND STORY ═══════════════════ -->
  <section class="section-padding bg-white">
    <div class="container-custom max-w-3xl mx-auto text-center">
      <div data-animate>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold-500 mb-4">
          Our Philosophy
        </p>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-slate-900 leading-tight mb-4">
          Why 048?
        </h2>
        <div class="gold-line mx-auto mb-8"></div>
        <p class="text-base md:text-lg text-slate-600 leading-relaxed mb-6">
          048 was born from a simple belief — that everyday meals deserve extraordinary ingredients. The name "048" represents the 48-hour quality assurance cycle that every batch of our rice undergoes before it earns the 048 seal.
        </p>
        <p class="text-base md:text-lg text-slate-600 leading-relaxed mb-6">
          From the moment a grain is harvested to the moment it reaches your kitchen, it passes through multiple stages of sorting, testing, aging, and quality validation. This meticulous attention to detail is what sets 048 apart.
        </p>
        <p class="text-base md:text-lg text-slate-600 leading-relaxed">
          When you choose 048, you're not just buying rice — you're investing in a promise of consistent, premium quality that transforms your everyday cooking into something truly special.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ MAJESTY COLLECTION ═══════════════════ -->
  <section class="section-padding bg-cream">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Image -->
        <div data-animate>
          <div class="relative rounded-2xl overflow-hidden shadow-2xl">
            <img
              src="https://images.unsplash.com/photo-1586201375761-83865001e31c?w=800&q=80"
              alt="048 Majesty Collection — Premium Basmati Rice"
              loading="lazy"
              decoding="async"
              class="w-full h-[400px] md:h-[500px] object-cover"
            />
            <div class="absolute top-6 left-6 bg-forest-900/90 backdrop-blur-sm px-4 py-2 rounded-full">
              <span class="text-[10px] font-bold uppercase tracking-widest text-gold-400">Collection</span>
            </div>
          </div>
        </div>

        <!-- Content -->
        <div data-animate>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold-500 mb-4">
            Collection
          </p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-slate-900 leading-tight mb-4">
            048 Majesty
          </h2>
          <div class="gold-line mb-6"></div>
          <p class="text-base text-slate-600 leading-relaxed mb-8">
            Premium tier Basmati rice. Perfect for daily cooking that demands extraordinary quality. Every grain is extra-long, naturally aged, and double-sortex cleaned to deliver consistent excellence in every meal.
          </p>
          <ul class="space-y-3 list-none p-0 m-0">
            {[
              "Extra-long grain Basmati (1121 variety)",
              "Naturally aged for enhanced aroma and elongation",
              "Double sortex cleaned for purity",
              "Ideal for daily cooking, biryani, and pulao",
              "Available in 1kg, 5kg, 10kg, and 25kg packs",
            ].map((feature) => (
              <li class="flex items-start gap-3">
                <div class="shrink-0 w-5 h-5 rounded-full bg-gold-100 flex items-center justify-center mt-0.5">
                  <svg class="w-3 h-3 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-sm text-slate-700">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ PLATINUM COLLECTION ═══════════════════ -->
  <section class="section-padding bg-white">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Content (first on mobile, second on desktop via order) -->
        <div class="order-2 lg:order-1" data-animate>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold-500 mb-4">
            Collection
          </p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold text-slate-900 leading-tight mb-4">
            048 Platinum
          </h2>
          <div class="gold-line mb-6"></div>
          <p class="text-base text-slate-600 leading-relaxed mb-8">
            The ultra-premium tier. Reserved for special occasions and the most discerning palates. Handpicked grains, extended aging, and a triple quality assurance process deliver an unparalleled rice experience.
          </p>
          <ul class="space-y-3 list-none p-0 m-0">
            {[
              "Handpicked select grains (top 5% of harvest)",
              "Extended 2-year aging process for supreme aroma",
              "Triple sortex + color sorting for flawless appearance",
              "Premium packaging with tamper-proof seal",
              "Available in 1kg, 5kg, and 10kg packs",
            ].map((feature) => (
              <li class="flex items-start gap-3">
                <div class="shrink-0 w-5 h-5 rounded-full bg-gold-100 flex items-center justify-center mt-0.5">
                  <svg class="w-3 h-3 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                  </svg>
                </div>
                <span class="text-sm text-slate-700">{feature}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Image -->
        <div class="order-1 lg:order-2" data-animate>
          <div class="relative rounded-2xl overflow-hidden shadow-2xl">
            <img
              src="https://images.unsplash.com/photo-1536304993881-460e32f50232?w=800&q=80"
              alt="048 Platinum Collection — Ultra-Premium Basmati Rice"
              loading="lazy"
              decoding="async"
              class="w-full h-[400px] md:h-[500px] object-cover"
            />
            <div class="absolute top-6 left-6 bg-forest-900/90 backdrop-blur-sm px-4 py-2 rounded-full">
              <span class="text-[10px] font-bold uppercase tracking-widest text-gold-400">Premium</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ DISTRIBUTION CTA ═══════════════════ -->
  <section class="section-padding bg-slate-50">
    <div class="container-custom text-center" data-animate>
      <SectionHeading
        overline="Distribution"
        title="Pan-India Presence, Growing Every Day"
        subtitle="048 is rapidly expanding across India. Join our network of premium rice distributors and bring the finest Basmati to your region."
      />

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 max-w-2xl mx-auto mt-12">
        {[
          { value: "10+", label: "States Covered" },
          { value: "200+", label: "Retail Partners" },
          { value: "100+", label: "MT Monthly Volume" },
        ].map((stat) => (
          <div class="text-center" data-animate>
            <p class="text-3xl md:text-4xl font-heading font-bold text-forest-600 mb-1">{stat.value}</p>
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-500">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════ LEAD FORM ═══════════════════ -->
  <LeadForm
    formId="distributor-form"
    formType="distributor"
    heading="Become a 048 Distributor"
    subtitle="Join India's fastest-growing premium rice brand. We offer attractive margins, marketing support, and a product that sells itself."
  />
</MasterLayout>
