---
interface Props {
  name: string;
  description: string;
}

const { name, description } = Astro.props;
---

<div class="bg-white rounded-xl border border-slate-100 p-6 text-center hover:shadow-lg hover:-translate-y-1 transition-all duration-500 group" data-animate>
  <!-- Shield Icon -->
  <div class="w-14 h-14 rounded-full bg-forest-50 flex items-center justify-center mx-auto mb-4 group-hover:bg-forest-100 transition-colors duration-300">
    <svg class="w-7 h-7 text-forest-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="1.5"
        d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
      />
    </svg>
  </div>

  <h4 class="text-sm md:text-base font-heading font-bold text-slate-900 mb-2">
    {name}
  </h4>
  <p class="text-xs md:text-sm text-slate-500 leading-relaxed m-0">
    {description}
  </p>
</div>
